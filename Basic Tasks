        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.linear_model import LinearRegression\n",
        "\n",
        "# 1. Create simple data (X = Height, y = Weight)\n",
        "X = np.array([[150], [160], [170], [180], [190]])\n",
        "y = np.array([50, 60, 65, 80, 85])\n",
        "\n",
        "# 2. Initialize and train the model\n",
        "model = LinearRegression()\n",
        "model.fit(X, y)\n",
        "\n",
        "# 3. Make a prediction for someone 175cm tall\n",
        "prediction = model.predict([[175]])\n",
        "print(f\"Predicted Weight for 175cm: {prediction[0]}\")\n",
        "\n",
        "# 4. Visualize\n",
        "plt.scatter(X, y, color='blue')\n",
        "plt.plot(X, model.predict(X), color='red')\n",
        "plt.title(\"Height vs Weight\")\n",
        "plt.show()"
      ],
